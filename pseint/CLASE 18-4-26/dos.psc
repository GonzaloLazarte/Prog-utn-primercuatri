Algoritmo sin_titulo
	Definir velocidadBici, distanciaCiudad, tiempo Como Real
	
	Escribir "ingrese la velocidad de bici"
	Leer velocidadBici
	
	Escribir "ingrese la distancia entre las dos ciudades"
	Leer distanciaCiudad
	
	tiempo = distanciaCiudad/velocidadBici
	
	Escribir "el tiempo que demora para de una ciudad a la otra es de: ", tiempo
	
	
FinAlgoritmo
