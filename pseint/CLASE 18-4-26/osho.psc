Algoritmo osho
	Definir celcius, kelvin, Farengei Como Real
	
	Escribir Sin Saltar "ingrese un valor en °C:"
	Leer celcius
	
	Farengei = (celcius * 1.8) + 32
	kelvin = celcius + 273.15
	
	Escribir "grados celcius: ", celcius, "°C"
	Escribir "grados fahrenheit: ", Farengei "°F"
	Escribir "grados kelvin: ", kelvin, "°K"
	
FinAlgoritmo
