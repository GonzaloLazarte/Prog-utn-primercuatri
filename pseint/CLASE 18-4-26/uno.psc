Algoritmo uno
	Definir costoBoleto, costoKilometro, kilometroRecorrido Como Real
	
	Escribir "ingrese la cantidad de kilometros recorridos: "
	Leer kilometroRecorrido
	
	Escribir "ingrese eel precio porkilometro: "
	Leer costoKilometro
	costoBoleto = kilometroRecorrido * costoKilometro
	
	Escribir "elprecio del boleto para ", kilometroRecorrido, " es de: " costoBoleto
	
FinAlgoritmo
